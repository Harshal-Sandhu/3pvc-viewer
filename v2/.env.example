# Copy to .env and fill in. Never commit .env.

# Bind address. Use 127.0.0.1 for local-only; 0.0.0.0 to expose on LAN.
HOST=127.0.0.1
PORT=3000

# Random 32+ char string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Admin login (full access: view + write/edit/delete sites + write compliance).
# Generate the hash with: npm run hash-password
ADMIN_USER=
ADMIN_PASSWORD_HASH=

# Viewer login (read-only access — cannot edit sites or write compliance data).
# Optional. If left blank, only the admin account can log in.
VIEWER_USER=
VIEWER_PASSWORD_HASH=

# Set to "production" to require HTTPS for the session cookie.
NODE_ENV=development

# Email — required for the admin "Send report" button AND the scheduler.
# The Gmail account that will SEND the mail (also acts as the "From").
GMAIL_USER=

# OAuth2 (Recommended, fully autonomous).
# Setup (one-time):
#   1. https://console.cloud.google.com/  → APIs & Services → Library → enable "Gmail API".
#   2. APIs & Services → OAuth consent screen → External, fill the basics.
#      Add yourself (GMAIL_USER above) as a test user.
#   3. APIs & Services → Credentials → "+ Create credentials" → OAuth client ID
#      → "Desktop app". Copy the client ID + secret into the two vars below.
#   4. Run `npm run oauth-setup` once — it opens a browser, you click Allow,
#      it writes GOOGLE_REFRESH_TOKEN here automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# OR — App Password fallback (if your org allows it).
# https://myaccount.google.com/apppasswords  (requires 2FA + admin allow)
# Only used if the three GOOGLE_* vars above are empty.
GMAIL_PASS=

# Fallback recipient when a site has no recipients configured.
# Comma-separated list allowed.
REPORT_RECIPIENT=

# Optional: timezone for scheduler cron jobs (e.g. "Asia/Kolkata", "America/New_York").
# If unset, scheduler.js uses the host system timezone.
SCHEDULER_TIMEZONE=
